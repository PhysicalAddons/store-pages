{% set secondary_features = [
    {
        'modifier': 'stars',
        'title': 'Stars',
        'subtitle': 'For memorable nights',
        'image': 'assets/images/features/stars-desktop.png',
        'mobile_image': 'assets/images/features/stars-mobile.png',
        'alt': 'Stars preview'
    },
    {
        'modifier': 'eclipses',
        'title': 'Eclipses',
        'subtitle': 'Because we can',
        'image': 'assets/images/features/eclipses-desktop.png',
        'mobile_image': 'assets/images/features/eclipses-mobile.png',
        'alt': 'Eclipses preview'
