{% set secondary_features = [
    {
        'modifier': 'stars',
        'title': 'Stars',
        'subtitle': 'For memorable nights',
        'image': 'assets/images/features/stars-desktop.jpg',
        'webp': 'assets/images/features/stars-desktop.webp',
        'mobile_image': 'assets/images/features/stars-mobile.jpg',
        'mobile_webp': 'assets/images/features/stars-mobile.webp',
        'alt': 'Stars preview'
    },
    {
        'modifier': 'eclipses',
        'title': 'Eclipses',
        'subtitle': 'Because we can',
        'video': 'assets/videos/eclipses.mp4',
        'video_webm': 'assets/videos/eclipses.webm',
        'poster': 'assets/videos/eclipses-poster.jpg',
        'alt': 'Eclipses preview'
    }
