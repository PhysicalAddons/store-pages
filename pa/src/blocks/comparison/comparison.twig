{% set comparison_columns = [
    {
        'modifier': 'primary',
        'title': 'Atmosphere',
        'mobile_title': 'PA2',
        'title_suffix': '2',
        'subtitle': 'New and updated\nPhysical Atmosphere2'
    },
    {
        'title': 'PSA',
        'mobile_title': 'PSA',
        'subtitle': 'Physical Starlight\nand Atmosphere'
    },
    {
        'title': 'Sky Texture',
        'mobile_title': 'Sky Texture',
        'subtitle': 'Blender Built-in\nSky Texture Modifier'
    }
] %}

{% set comparison_groups = [
    {
        'title': 'Atmosphere',
        'rows': [
            {
                'label': 'Multiple Scattering',
                'a2': true,
                'psa': false,
                'sky': true,
                'tooltip_title': 'Multiple Scattering',
                'tooltip_text': 'Softens atmospheric light by bouncing it through the air, giving skies and horizons a richer result.'
            },
            {
                'label': 'Round Planet',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Round Planet',
                'tooltip_text': 'Keeps the horizon and atmosphere curvature believable for large scale shots and space views.'
            },
            {
                'label': 'Spectral atmosphere',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Spectral Atmosphere',
                'tooltip_text': 'Uses wavelength-aware color behavior so sunsets, skies and haze feel more physically grounded.'
            },
            {
                'label': 'Atmospheric Refraction',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Atmospheric Refraction',
                'tooltip_text': 'Light bends as it passes through air of varying density — keeps the horizon and sunset positions astronomically correct.'
            },
            {
                'label': 'Air Glow',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Air Glow',
                'tooltip_text': 'Faint natural glow from the upper atmosphere that gives deep night skies depth instead of pitch black.'
            },
            {
                'label': 'Ozone Integral',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Ozone Integral',
                'tooltip_text': 'Models how the ozone layer tints twilight, especially that distinctive blue-purple band low on the horizon.'
            },
            {
                'label': 'Pollution OPAC',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Pollution (OPAC)',
                'tooltip_text': 'Real-world aerosol and pollution data so haze, smog and dust look physically grounded rather than just darker air.'
            },
            {
                'label': 'Earth Texture',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Earth Texture',
                'tooltip_text': 'True-Earth surface and cloud cover for shots from above the atmosphere, so the planet looks like home.'
            }
        ]
    },
    {
        'title': 'Sky & Lighting',
        'rows': [
            {
                'label': 'Clouds',
                'a2': true,
                'a2_double': true,
                'psa': true,
                'sky': false,
                'tooltip_title': 'Clouds',
                'tooltip_text': 'Volumetric clouds driven by procedural noise — shape, density and lighting are all calculated, not painted on.'
            },
            {
                'label': 'Night Sky',
                'a2': true,
                'psa': true,
                'sky': false,
                'tooltip_title': 'Night Sky',
                'tooltip_text': 'Star field, milky way and planet positions that match real astronomy for a given date and location.'
            },
            {
                'label': 'Spherical Sun',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Spherical Sun',
                'tooltip_text': 'The sun rendered as a true sphere — not a billboard — so its glow, refraction and limb darkening feel right.'
            },
            {
                'label': 'Spectral Sun',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Spectral Sun',
                'tooltip_text': 'Wavelength-aware sunlight so colour and intensity shift naturally from dawn through midday to dusk.'
            },
            {
                'label': 'Eclipses',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Eclipses',
                'tooltip_text': 'Solar and lunar eclipses solved geometrically — set the date and the alignment just works.'
            }
        ]
    },
    {
        'title': 'Celestial Objects',
        'rows': [
            {
                'label': 'Moon',
                'a2': true,
                'psa': true,
                'sky': false,
                'tooltip_title': 'Moon',
                'tooltip_text': 'Real moon phase, position and surface texture driven by the scene date and observer location.'
            },
            {
                'label': 'Real Stars',
                'a2': true,
                'psa': true,
                'sky': false,
                'tooltip_title': 'Real Stars',
                'tooltip_text': 'Star catalogue with real coordinates and magnitudes so the night sky matches what you would actually see.'
            },
            {
                'label': 'Constellations',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Constellations',
                'tooltip_text': 'Optional constellation overlay for previs and orientation when composing night-sky shots.'
            }
        ]
    },
    {
        'title': 'Workflow',
        'rows': [
            {
                'label': 'Artistic Controls',
                'a2': true,
                'psa': true,
                'sky': false,
                'tooltip_title': 'Artistic Controls',
                'tooltip_text': 'Nudge the physics where you need to — adjust the mood without breaking the underlying simulation.'
            },
            {
                'label': 'Bake HDRI',
                'a2': true,
                'psa': true,
                'sky': false,
                'tooltip_title': 'Bake HDRI',
                'tooltip_text': 'Capture the current sky as an HDRI in one click — use it in other tools or lock a look you like.'
            },
            {
                'label': 'Position',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Position',
                'tooltip_text': 'Set latitude, longitude, date and time — the addon places the sun, moon and stars accordingly.'
            },
            {
                'label': 'Advanced Mode',
                'a2': true,
                'psa': false,
                'sky': false,
                'tooltip_title': 'Advanced Mode',
                'tooltip_text': 'Exposes every physics knob — multiple-scattering quality, ozone density, fog falloff — for full control.'
            }
        ]
    }
] %}

<div class="comparison block" id="comparison">
    <h2 class="comparison__title">Comparison</h2>

    <div class="comparison__table-wrap">
        <table class="comparison__table">
            <colgroup>
                <col class="comparison__col comparison__col--label">
                <col class="comparison__col comparison__col--a2">
                <col class="comparison__col comparison__col--psa">
                <col class="comparison__col comparison__col--sky">
            </colgroup>

            <thead>
                <tr>
                    <th></th>
                    {% for column in comparison_columns %}
                        <th class="comparison__product comparison__product{{ column.modifier is defined ? ' comparison__product--' ~ column.modifier : '' }}">
                            <div class="comparison__product-title">
                                {{ column.title }}{% if column.title_suffix is defined %}<sup>{{ column.title_suffix }}</sup>{% endif %}
                            </div>
                            <div class="comparison__product-subtitle">{{ column.subtitle|nl2br }}</div>
                        </th>
                    {% endfor %}
                </tr>
            </thead>

            <tbody>
                {% for group in comparison_groups %}
                    <tr class="comparison__group-row">
                        <th class="comparison__group-title" scope="colgroup">{{ group.title }}</th>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>

                    {% for row in group.rows %}
                        <tr class="comparison__feature-row">
                            <th class="comparison__feature-label" scope="row">
                                {% if row.tooltip_title is defined %}
                                    <span class="comparison__info-tooltip tooltip tooltip--side" tabindex="0" aria-label="{{ row.tooltip_title }}">
                                        <img src="assets/images/icons/info.svg" alt="" aria-hidden="true">
                                        <span class="tooltip__content">
                                            <strong>{{ row.tooltip_title }}</strong>
                                            <span>{{ row.tooltip_text }}</span>
                                        </span>
                                    </span>
                                {% else %}
                                    <img src="assets/images/icons/info.svg" alt="" aria-hidden="true">
                                {% endif %}
                                <span>{{ row.label }}</span>
                            </th>
                            <td class="comparison__value-cell">
                                <span class="comparison__value comparison__value--yes{{ row.a2_double ? ' comparison__value--double' : '' }}">✓</span>
                            </td>
                            <td class="comparison__value-cell">
                                <span class="comparison__value comparison__value--{{ row.psa ? 'yes' : 'no' }}">{{ row.psa ? '✓' : '‒' }}</span>
                            </td>
                            <td class="comparison__value-cell">
                                <span class="comparison__value comparison__value--{{ row.sky ? 'yes' : 'no' }}">{{ row.sky ? '✓' : '‒' }}</span>
                            </td>
                        </tr>
                    {% endfor %}
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="comparison__mobile">
        <div class="comparison__mobile-head">
            <div class="comparison__mobile-spacer" aria-hidden="true"></div>
            {% for column in comparison_columns %}
                <div class="comparison__mobile-product comparison__mobile-product{{ column.modifier is defined ? ' comparison__mobile-product--' ~ column.modifier : '' }}">
                    {{ column.mobile_title }}
                </div>
            {% endfor %}
        </div>

        {% for group in comparison_groups %}
            <section class="comparison__mobile-group">
                <h3 class="comparison__mobile-group-title">{{ group.title }}</h3>

                {% for row in group.rows %}
                    <div class="comparison__mobile-row">
                        <div class="comparison__mobile-label">
                            {% if row.tooltip_title is defined %}
                                <span class="comparison__info-tooltip tooltip tooltip--side" tabindex="0" aria-label="{{ row.tooltip_title }}">
                                    <img src="assets/images/icons/info.svg" alt="" aria-hidden="true">
                                    <span class="tooltip__content">
                                        <strong>{{ row.tooltip_title }}</strong>
                                        <span>{{ row.tooltip_text }}</span>
                                    </span>
                                </span>
                            {% else %}
                                <img src="assets/images/icons/info.svg" alt="" aria-hidden="true">
                            {% endif %}
                            <span>{{ row.label }}</span>
                        </div>
                        <div class="comparison__mobile-value comparison__mobile-value--yes{{ row.a2_double ? ' comparison__mobile-value--double' : '' }}">✓</div>
                        <div class="comparison__mobile-value comparison__mobile-value--{{ row.psa ? 'yes' : 'no' }}">{{ row.psa ? '✓' : '‒' }}</div>
                        <div class="comparison__mobile-value comparison__mobile-value--{{ row.sky ? 'yes' : 'no' }}">{{ row.sky ? '✓' : '‒' }}</div>
                    </div>
                {% endfor %}
            </section>
        {% endfor %}
    </div>
</div>