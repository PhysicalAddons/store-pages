{% set overview_points = [
    {
        'label': 'Realtime',
        'width': 114
    },
    {
        'label': 'Intuitive Controls',
        'width': 209
    },
    {
        'label': 'Physics Based',
        'width': 180
    },
    {
        'label': 'Advanced Mode',
        'width': 202
    },
    {
        'label': 'Artistic Tools',
        'width': 164
    }
] %}

<div class="overview block" id="overview">
    <h2 class="overview__title">Feels Like Magic.</h2>

    <div class="overview__card">
        <picture class="overview__media">
            <source media="(max-width: 767px)" srcset="assets/images/overview/overview-media-mobile.png">
            <img
                class="overview__image"
                src="assets/images/overview/overview-media.png"
                alt="Physical Atmosphere interface in Blender"
            >
        </picture>

        <div class="overview__points" role="tablist" aria-label="Overview features">
            {% for point in overview_points %}
                <button
                    class="overview__point {{ loop.first ? 'overview__point--active' : '' }}"
                    type="button"
                    role="tab"
                    aria-selected="{{ loop.first ? 'true' : 'false' }}"
                    style="width: {{ point.width }}px;"
                    data-overview-tab
                >
                    {{ point.label }}
                </button>
            {% endfor %}
        </div>
    </div>
</div>
